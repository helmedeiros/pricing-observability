{
  "title": "markup-svc — Decide overview",
  "uid": "markup-decide-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "tags": ["pricing-platform", "markup-svc"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Decide RPS by outcome",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(markup_decide_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Decide RPS by adapter",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (adapter) (rate(markup_decide_total[1m]))",
          "legendFormat": "{{adapter}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Decide latency — p50 / p95 / p99",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(markup_decide_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(markup_decide_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(markup_decide_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error rate (5m)",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(markup_decide_total{outcome=\"error\"}[5m])) / sum(rate(markup_decide_total[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "No-match rate (5m)",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(markup_decide_total{outcome=\"no_match\"}[5m])) / sum(rate(markup_decide_total[5m]))",
          "legendFormat": "no-match rate",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3 } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Challenger agreement RPS (ADR-0032)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (agree) (rate(markup_challenger_agreement_total[1m]))",
          "legendFormat": "agree={{agree}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Challenger one-sided + timeout + error RPS",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (side) (rate(markup_challenger_one_sided_total[1m]))",
          "legendFormat": "{{side}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(markup_challenger_eval_timeout_total[1m]))",
          "legendFormat": "timeout",
          "refId": "B"
        },
        {
          "expr": "sum(rate(markup_challenger_eval_errors_total[1m]))",
          "legendFormat": "error",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Agreement ratio (5m)",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(markup_challenger_agreement_total{agree=\"true\"}[5m])) / sum(rate(markup_challenger_agreement_total[5m]))",
          "legendFormat": "agreement",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Eval-timeout rate (5m)",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(markup_challenger_eval_timeout_total[5m])) / (sum(rate(markup_challenger_agreement_total[5m])) + sum(rate(markup_challenger_eval_timeout_total[5m])))",
          "legendFormat": "timeout rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Factor delta p50/p95/p99 on disagreement",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(markup_challenger_factor_delta_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(markup_challenger_factor_delta_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(markup_challenger_factor_delta_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Effective sample rate (5m, ADR-0033)",
      "gridPos": { "x": 0, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(markup_challenger_sampled_total{sampled=\"true\"}[5m])) / sum(rate(markup_challenger_sampled_total[5m]))",
          "legendFormat": "sampled rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Champion vs challenger Decide p99",
      "gridPos": { "x": 6, "y": 32, "w": 18, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(markup_decide_duration_seconds_bucket[5m])))",
          "legendFormat": "champion p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(markup_challenger_decide_duration_seconds_bucket[5m])))",
          "legendFormat": "challenger p99",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(markup_decide_duration_seconds_bucket[5m])))",
          "legendFormat": "champion p95",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(markup_challenger_decide_duration_seconds_bucket[5m])))",
          "legendFormat": "challenger p95",
          "refId": "D"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
