{
  "title": "decision-gateway — overview",
  "uid": "decision-gateway-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "tags": ["pricing-platform", "decision-gateway"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "RPS by route",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(route) (rate(gateway_requests_total[1m]))", "legendFormat": "{{route}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "RPS by status",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(status) (rate(gateway_requests_total[1m]))", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency — p50 / p95 / p99",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by(le) (rate(gateway_request_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by(le) (rate(gateway_request_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by(le) (rate(gateway_request_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "5xx rate (5m)",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(gateway_requests_total{status=~\"5..\"}[5m])) / sum(rate(gateway_requests_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.001 },
            { "color": "red", "value": 0.01 }
          ]}
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "4xx rate (5m)",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(gateway_requests_total{status=~\"4..\"}[5m])) / sum(rate(gateway_requests_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3 } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p99 by route",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by(le, route) (rate(gateway_request_duration_seconds_bucket{route!=\"\"}[5m])))", "legendFormat": "{{route}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "p95 by route",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by(le, route) (rate(gateway_request_duration_seconds_bucket{route!=\"\"}[5m])))", "legendFormat": "{{route}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
